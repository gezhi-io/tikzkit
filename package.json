{
  "name": "pure-js-tikz-interpreter",
  "version": "0.1.0",
  "description": "A pure JavaScript TikZ semantic interpreter that renders supported TikZ to SVG.",
  "type": "module",
  "bin": {
    "tikz2svg": "./bin/tikz2svg.js"
  },
  "scripts": {
    "test": "node --test",
    "web": "node web/server.js",
    "extension-registry": "node scripts/build-extension-registry.js",
    "awesome-tikz:audit": "node scripts/awesome-tikz-audit.js",
    "real-cases:render": "node scripts/render-real-cases.js",
    "gallery:audit": "node scripts/gallery-audit.js",
    "gallery:native": "node scripts/gallery-native.js",
    "gallery:js": "node scripts/gallery-js.js",
    "gallery:diff": "python3 scripts/gallery-diff.py",
    "gallery:sheet": "python3 scripts/gallery-visual-sheet.py",
    "corpus:render": "node scripts/corpus-render.js",
    "corpus:sheet": "python3 scripts/corpus-visual-sheet.py",
    "circuitikz:audit": "node scripts/circuitikz-audit.js",
    "f0nzie:audit": "node scripts/f0nzie-audit.js",
    "janosh:audit": "node scripts/janosh-audit.js",
    "structural-analysis:audit": "node scripts/structural-analysis-audit.js",
    "walmes:audit": "node scripts/walmes-audit.js"
  },
  "dependencies": {
    "chevrotain": "^11.0.3",
    "katex": "^0.17.0"
  }
}
